          "${RUNTIME:-podman}" "$(compose_file "$box")"
      fi
      if [[ -f $(ini_file "$box") ]]; then
        printf '    distrobox assemble create --file %s\n' "$(ini_file "$box")"
      fi
    done
    printf '\n## Distrobox lane\n\n'
    printf 'Distroboxes get the SAME in-box mounts as the server lane: the\n'
    printf 'init hook mounts the overlays, surfaces, and caches from your\n'
    printf 'data dir (/opt/data in-box), so in-box installs (pip packages,\n'
    printf 'custom nodes) persist across box recreation. The overlay-hostile\n'
    printf 'filesystem rule therefore applies to BOTH lanes. Boxes created\n'
    printf 'by v0.1.0-era setups must be recreated (distrobox rm <name>,\n'
    printf 'then the assemble one-liner above) to pick this up.\n'
    printf '\n## Auto-start\n\n'
    printf 'Boxes with auto-start use `restart: unless-stopped`. For rootless\n'
    printf 'podman that policy is applied at boot by a user service — enable it\n'
    printf 'once:\n\n'
    printf '    systemctl --user enable --now podman-restart.service\n'
    printf '    loginctl enable-linger %s   # start user services at boot\n\n' \
      "${USER:-$(id -un)}"
    printf '## Shared model store\n\n'
    printf 'Every box binds `%s`. Download once, use everywhere:\n\n' "$HF_CACHE"
    printf '    hf download <org>/<repo>       # or: huggingface-cli download\n\n'
    printf 'ComfyUI re-scans the cache at each start (symlink model tree).\n'
    printf '\n## Installer choices (record)\n\n'
    printf -- '- Date: %s; emit dir: `%s`; runtime: %s%s.\n' \
      "$(date +%F)" "$EMIT_DIR" "${RUNTIME:-none}" \
      "$([[ $ROOTLESS -eq 1 ]] && echo ' (rootless)')"
    printf -- '- group_add mode: %s.\n' \
      "$([[ $GROUP_MODE == keep-groups ]] && echo 'keep-groups (rootless podman)' \
         || echo "numeric GIDs (${GROUP_GIDS:-none found})")"
    for box in "${CONFIGURE[@]}"; do
      note=""
      case "${CFG_MODE[$box]:-}" in
        fuse) note="fs=${CFG_FS[$box]} → DROSTE_OVERLAY_MODE=fuse + /dev/fuse" ;;
        copy) note="fs=${CFG_FS[$box]} → DROSTE_OVERLAY_MODE=copy" ;;
        ignore) note="fs=${CFG_FS[$box]} → IGNORED (box will fail on start!)" ;;
        *) note="fs=${CFG_FS[$box]:-?} (kernel overlayfs OK)" ;;
      esac
      printf -- '- %s: lane=%s, data=`%s`, %s.%s\n' \
        "$box" "${CFG_LANE[$box]}" "${PATHS["$box:data"]}" "$note" \
        "$([[ -n ${BOX_CONFIG[$box]} ]] \
           && printf ' Seeded config: %s.' "${BOX_CONFIG[$box]}")"
    done
    printf '\nEscape hatch: `-e ALLOW_EPHEMERAL=1` downgrades missing-critical-\n'
    printf 'bind errors to warnings (NOT recommended — data will not persist).\n'
    printf '\n## Health check\n\n'
    printf 'On the GPU host, the repo'\''s `scaffolding/check-rocm.sh` validates\n'
    printf 'GPU access + per-box smoke across all images (see its --help).\n'
  } > "$f"
  say "  wrote $(home_disp "$f")"
  return 0
}

# ── Status dashboard ─────────────────────────────────────────────────────────
box_lanes_disp() {  # box → server|distrobox|both from config or detection
  local box=$1
  if [[ -n "${CFG_LANE[$box]:-}" ]]; then
    printf '%s' "${CFG_LANE[$box]}"
  else
    printf '%s' "${EXD_LANE[$box]:-none}"
  fi
}
box_port_disp() {
  local box=$1
  printf '%s' "${CFG_PORT[$box]:-${EXD_PORT[$box]:--}}"
}
box_as() {
  local box=$1
  if [[ -n "${CFG_LANE[$box]:-}" ]]; then
    printf '%s' "${CFG_AS[$box]:-}"
  else
    printf '%s' "${EXD_AS[$box]:-}"
  fi
}

box_state() {  # box → ACTIVE|STOPPED|none
  local box=$1 state=""
  if [[ -n $RUNTIME ]]; then
    state=$("$RUNTIME" ps -a --filter "name=^${NAME_PREFIX}${box}\$" \
            --format '{{.State}}' 2>/dev/null | head -n1) || state=""
  fi
  if [[ -z $state ]]; then
    if [[ -n "${SESSION_STATE[$box]:-}" ]]; then
      printf '%s' "${SESSION_STATE[$box]}"
    elif [[ -n "${EX_CTR[$box]:-}" ]]; then
      [[ ${EX_CTR[$box]} == running ]] && printf 'ACTIVE' || printf 'STOPPED'
    elif [[ -n "${EX_DBX[$box]:-}" ]]; then
      printf 'STOPPED'
    else
      printf 'none'
    fi
  else
    [[ $state == running ]] && printf 'ACTIVE' || printf 'STOPPED'
  fi
}

dashboard() {
  local box lane st stg stw g note data row port
  say ""
  hdr "Box Status"
  say "Legend: St state - Db distrobox - Sv server - AS auto-start ($G_YES yes / $G_NO no)"
  printf '%s%s%s\n' "$ULINE" \
    "$(pad_cell "Box" 3 11)$(pad_cell "St" 2 12)$(pad_cell "Db" 2 3)$(pad_cell "Sv" 2 3)$(pad_cell "AS" 2 3)$(pad_cell "Port" 4 5)Important Notes" \
    "$RESET"
  for box in "${SELECTED[@]}"; do
    lane=$(box_lanes_disp "$box")
    st=$(box_state "$box")
    case "$st" in
      ACTIVE)  stg=$G_ACTIVE;  stw=$W_ACTIVE ;;
      STOPPED) stg=$G_STOPPED; stw=$W_STOPPED ;;
      *)       stg=$G_NONE;    stw=$W_NONE ;;
    esac
    row=$(pad_cell "$box" ${#box} 11)
    row+=$(pad_cell "$stg" "$stw" 12)
    [[ $lane == distrobox || $lane == both ]] && g=$G_YES || g=$G_NO
    row+=$(pad_cell "$g" "$W_GLYPH" 3)
    [[ $lane == server || $lane == both ]] && g=$G_YES || g=$G_NO
    row+=$(pad_cell "$g" "$W_GLYPH" 3)
    [[ -n "$(box_as "$box")" ]] && g=$G_YES || g=$G_NO
    row+=$(pad_cell "$g" "$W_GLYPH" 3)
    port=$(box_port_disp "$box")
    row+=$(pad_cell "$port" ${#port} 5)
    data="${PATHS["$box:data"]:-${EXD_PATH["$box:data"]:-}}"
    note=${BOX_NOTE[$box]//@DATA@/$(home_disp "${data:-~/droste/$box/data}")}
    [[ ${#note} -gt 42 ]] && note="${note:0:39}..."
    printf '%s%s\n' "$row" "$note"
  done
  say ""
  hdr "Shortcuts"
  say "  Enter a box:        distrobox enter ${NAME_PREFIX}<box>"
  say "  Start/stop server:  podman start|stop ${NAME_PREFIX}<box>"
  say "  Recreate (from $(home_disp "$EMIT_DIR")):"
  say "    server:    podman compose -f ${NAME_PREFIX}<box>.compose.yaml up -d"
  say "    distrobox: distrobox assemble create --file ${NAME_PREFIX}<box>.ini"
  say "* ComfyUI models are scanned at start; add more: hf download (shared cache)"
  say "Definitions + full guide: $(home_disp "$EMIT_DIR") (compose.yaml, ini, NOTES.md)"
  return 0
}

# ── Main flow ────────────────────────────────────────────────────────────────
main() {
  init_input
  say "droste-setup — guided install for the droste *-halo AI boxes"
  preflight

  section "Where to keep the definitions"
  wrap "Per-box recreation records (compose.yaml + distrobox ini) and NOTES.md are written to an emit dir; default data dirs live under it too."
  # A typo here fans out into every emitted file — confirm before creating.
  while :; do
    ask_path_raw "the definitions (emit dir)" "$HOME/droste"
    if [[ -d $ANS_PATH ]]; then
      break
    fi
    ask_yn "Create $ANS_PATH?" Y
    if [[ $ANS_YN -eq 1 ]]; then
      if mkdir -p "$ANS_PATH" 2>/dev/null; then
        break
      fi
      warn "could not create $ANS_PATH — pick another location"
    fi
  done
  EMIT_DIR=$ANS_PATH
  DEFAULT_ROOT=$EMIT_DIR

  detect_existing
  select_boxes
  resolve_actions

  if [[ ${#CONFIGURE[@]} -gt 0 ]]; then
    shared_questions
    local i n box
    n=${#CONFIGURE[@]}
    for (( i = 0; i < n; i = i + 1 )); do
      box=${CONFIGURE[$i]}
      configure_box "$box" $(( n - i - 1 ))
    done
    ask_ladder
    execute
    write_notes
  else
    say ""
    say "Nothing to change (all selected boxes kept as-is)."
  fi

  dashboard
  return 0
}

main
