# ── Status dashboard ─────────────────────────────────────────────────────────
box_lanes_disp() {  # box → server|distrobox|both from config or detection
  local box=$1
  if [[ -n "${CFG_LANE[$box]:-}" ]]; then
    printf '%s' "${CFG_LANE[$box]}"
  else
    printf '%s' "${EXD_LANE[$box]:-none}"
  fi
}
box_port_disp() {
  local box=$1
  printf '%s' "${CFG_PORT[$box]:-${EXD_PORT[$box]:--}}"
}
box_as() {
  local box=$1
  if [[ -n "${CFG_LANE[$box]:-}" ]]; then
    printf '%s' "${CFG_AS[$box]:-}"
  else
    printf '%s' "${EXD_AS[$box]:-}"
  fi
}

box_state() {  # box → ACTIVE|STOPPED|none
  local box=$1 state=""
  if [[ -n $RUNTIME ]]; then
    state=$("$RUNTIME" ps -a --filter "name=^$(server_name "$box")\$" \
            --format '{{.State}}' 2>/dev/null | head -n1) || state=""
  fi
  if [[ -z $state ]]; then
    if [[ -n "${SESSION_STATE[$box]:-}" ]]; then
      printf '%s' "${SESSION_STATE[$box]}"
    elif [[ -n "${EX_CTR[$box]:-}" ]]; then
      [[ ${EX_CTR[$box]} == running ]] && printf 'ACTIVE' || printf 'STOPPED'
    elif [[ -n "${EX_DBX[$box]:-}" ]]; then
      printf 'STOPPED'
    else
      printf 'none'
    fi
  else
    [[ $state == running ]] && printf 'ACTIVE' || printf 'STOPPED'
  fi
}

dashboard() {
  local box lane st stg stw g note data row port
  say ""
  hdr "Box Status"
  say "Legend: State $GS_ACTIVE active / $GS_STOPPED stopped / $GS_NONE none — Box=distrobox, Server, AS=auto-start ($G_YES/$G_NO)"
  printf '%s%s%s\n' "$ULINE" \
    "$(pad_cell "Box" 3 11)$(pad_cell "State" 5 7)$(pad_cell "Box" 3 5)$(pad_cell "Server" 6 8)$(pad_cell "AS" 2 4)$(pad_cell "Port" 4 6)Important Notes" \
    "$RESET"
  for box in "${SELECTED[@]}"; do
    lane=$(box_lanes_disp "$box")
    st=$(box_state "$box")
    case "$st" in
      ACTIVE)  stg=$GS_ACTIVE ;;
      STOPPED) stg=$GS_STOPPED ;;
      *)       stg=$GS_NONE ;;
    esac
    row=$(pad_cell "$box" ${#box} 11)
    row+=$(pad_cell "$stg" "$W_STATE" 7)
    [[ $lane == distrobox || $lane == both ]] && g=$G_YES || g=$G_NO
    row+=$(pad_cell "$g" "$W_GLYPH" 5)
    [[ $lane == server || $lane == both ]] && g=$G_YES || g=$G_NO
    row+=$(pad_cell "$g" "$W_GLYPH" 8)
    [[ -n "$(box_as "$box")" ]] && g=$G_YES || g=$G_NO
    row+=$(pad_cell "$g" "$W_GLYPH" 4)
    port=$(box_port_disp "$box")
    row+=$(pad_cell "$port" ${#port} 6)
    data="${PATHS["$box:data"]:-${EXD_PATH["$box:data"]:-}}"
    note=${BOX_NOTE[$box]//@DATA@/$(home_disp "${data:-~/droste/$box/data}")}
    [[ ${#note} -gt 42 ]] && note="${note:0:39}..."
    printf '%s%s\n' "$row" "$note"
  done
  say ""
  hdr "Shortcuts"
  say "  Enter box:          distrobox enter droste-<box>-halo-box"
  say "  Start/stop server:  podman start|stop droste-<box>-halo-server"
  printf '%s%s%s\n' "$ULINE" "  Recreate (files in $(home_disp "$EMIT_DIR"))" "$RESET"
  say "    server:    podman compose -f droste-<box>-halo-server.compose.yaml up -d"
  say "    distrobox: distrobox assemble create --file droste-<box>-halo-box.ini"
  say "* ComfyUI models scanned at start; to add more run: hf download <shared cache>"
  say "--> Definitions + full guide: $(home_disp "$EMIT_DIR") (compose.yaml, ini, NOTES.md)"
  return 0
}

# ── Main flow ────────────────────────────────────────────────────────────────
main() {
  init_input
  banner "Droste Installer for Halo Architectures"
  preflight

  section "Resource Path"
  sub "Recreation (compose.yaml/distrobox ini), logs, & program data"
  # A typo here fans out into every emitted file — confirm before creating.
  while :; do
    ask_path_as_raw "Please Identify a path to use for droste resources" "$HOME/droste"
    if [[ -d $ANS_PATH ]]; then
      break
    fi
    ask_yn "Create $ANS_PATH?" Y
    if [[ $ANS_YN -eq 1 ]]; then
      if mkdir -p "$ANS_PATH" 2>/dev/null; then
        break
      fi
      warn "could not create $ANS_PATH — pick another location"
    fi
  done
  EMIT_DIR=$ANS_PATH
  DEFAULT_ROOT=$EMIT_DIR

  detect_existing
  select_boxes
  resolve_actions

  if [[ ${#CONFIGURE[@]} -gt 0 || ${#KEEP[@]} -gt 0 ]]; then
    local i n box
    if [[ ${#CONFIGURE[@]} -gt 0 ]]; then
      shared_questions
      n=${#CONFIGURE[@]}
      for (( i = 0; i < n; i = i + 1 )); do
        box=${CONFIGURE[$i]}
        configure_box "$box" $(( n - i - 1 ))
      done
    fi
    # Kept boxes: reuse their recorded config so the ladder can pull/create/
    # start them (e.g. a prior "write only" run) without rewriting anything.
    for box in "${KEEP[@]}"; do hydrate_keep "$box"; done
    if [[ ${#CONFIGURE[@]} -eq 0 ]]; then
      say ""
      say "All selected boxes kept as-is — definitions unchanged."
      say "You can still pull images / create / start them below."
    fi
    ask_ladder
    execute
    write_notes
    # For any created distrobox lane, show the enter command (best-effort).
    if [[ $RUNG == c || $RUNG == a ]]; then
      for box in "${SELECTED[@]}"; do
        [[ ${CFG_LANE[$box]:-} != server ]] || continue
        printf 'To enter, run: %s%s%s\n' "$BOLD" "distrobox enter $(dbox_name "$box")" "$RESET"
      done
    fi
  else
    say ""
    say "No boxes selected."
  fi

  dashboard
  return 0
}

main
