# finetuning-artifacts: gfx1151 native builds for the LLM-finetuning toolbox, collected onto a
# FROM-scratch carrier consumed by finetuning-runtime via `COPY --from`. Same seam pattern as
# llama/ds4/vllm artifacts: this stage compiles ONLY the project's own gfx1151 outputs; the ROCm
# runtime kernels + torch come from the runtime base, NOT this carrier.
#
# Two things are built here (translated from the upstream multistage Dockerfile
# github.com/kyuz0/amd-strix-halo-llm-finetuning @ 093a23c0d49418aef08e5053aa19faf65b35236a):
#   1. bitsandbytes (ROCm/hip backend, gfx1151)  → a wheel in /artifacts/wheels
#   2. a custom RCCL for gfx1151                  → librccl.so.1 in /artifacts/lib64
#
# UPSTREAM DELTAS (deliberate):
#   * The upstream `/opt/rocm-7.0` TheRock S3 TARBALL fetch is DROPPED entirely. Our base
#     (rocm-build-base) already provides the pip TheRock ROCm SDK at ROCM_PATH=/opt/rocm
#     (rocm-sdk-devel: hipcc/amdclang++ + HIP headers + device bitcode). All `/opt/rocm-7.0`
#     references become ${ROCM_PATH} = /opt/rocm.
#   * Upstream does NOT build RCCL — it `COPY`s a prebuilt `custom_libs/librccl.so.1.gz` produced
#     by a separate CI workflow (build-rccl.yml in the vllm-toolboxes repo). We instead build RCCL
#     from source here, using that workflow's recipe (scripts/build_rccl_gfx1151.sh:
#     kyuz0/rocm-systems @ branch gfx1151-rccl, projects/rccl). This makes the port self-contained.
#   * bitsandbytes is packaged as a WHEEL (not `pip install`ed) so the runtime stage installs it
#     into its own venv. The upstream runtime version-parse symlink fixup happens in the runtime
#     Containerfile (after install), not here.

ARG BASE_IMAGE=localhost/rocm-build-base
FROM ${BASE_IMAGE} AS builder
# Local podman builds need the localhost/ prefix (default above); CI can override:
#   --build-arg BASE_IMAGE=ghcr.io/<owner>/rocm-build-base:<tag>

LABEL description="finetuning-artifacts: gfx1151 bitsandbytes wheel + custom RCCL (scratch carrier)"

# --- The unified pin (rocm-pin.env). ARG names MUST match the env keys the wrapper passes. ---
ARG ROCM_INDEX_URL=https://rocm.nightlies.amd.com/v2/gfx1151/
ARG TORCH_VERSION=2.9.1+rocm7.13.0a20260501
ARG GFX_TARGET=gfx1151

# --- Clone pins (provenance). ------------------------------------------------------------------
# FLAG (on-host): these float upstream HEAD and MUST get sha pins before a reproducible release.
#   * BITSANDBYTES_REF: upstream builds bitsandbytes-foundation/bitsandbytes @ main (ROCm v0.46.1+).
#   * RCCL_REPO/RCCL_REF: kyuz0/rocm-systems @ branch gfx1151-rccl (a moving branch head).
# Override with an immutable commit sha via --build-arg once locked on the Strix Halo / CI builder.
ARG BITSANDBYTES_REPO=https://github.com/bitsandbytes-foundation/bitsandbytes.git
ARG BITSANDBYTES_REF=main
ARG RCCL_REPO=https://github.com/kyuz0/rocm-systems.git
ARG RCCL_REF=gfx1151-rccl

# Pinned torch into the build venv. bitsandbytes' hip build/packaging detects the installed ROCm
# (and, for the runtime lib name, the torch/ROCm version) via the same interpreter it ships for.
# (Thrown away with this builder stage — only the wheel + librccl reach the scratch carrier.)
RUN pip install --index-url ${ROCM_INDEX_URL} "torch==${TORCH_VERSION}"

# Carrier layout mirrors the other ports: wheels/ for pip-installables, lib64/ for raw .so.
RUN mkdir -p /artifacts/wheels /artifacts/lib64

# PEP517 build backends for the wheel repackage steps below. bitsandbytes main uses
# scikit_build_core.setuptools.build_meta, and `pip wheel --no-build-isolation` requires the
# backend to be importable in the venv already (torch does not pull it).
RUN pip install --upgrade scikit-build-core setuptools wheel

# --- bitsandbytes (ROCm / hip backend, gfx1151) ------------------------------------------------
# In-source cmake (COMPUTE_BACKEND=hip) emits libbitsandbytes_rocm*.so into the package tree;
# `pip wheel` then bundles that prebuilt .so. hipcc/HIP come from rocm-sdk-devel (ROCM_PATH set by
# the base). OpenMP: cmake find_package(OpenMP) resolves Debian's libomp-dev
# (/usr/lib/x86_64-linux-gnu/libomp.so, installed in rocm-build-base) — no Fedora /usr/lib64 path.
WORKDIR /opt
RUN git clone "${BITSANDBYTES_REPO}" bitsandbytes \
    && cd bitsandbytes \
    && git checkout "${BITSANDBYTES_REF}" \
    && cmake -S . -DGPU_TARGETS="${GFX_TARGET}" \
              -DBNB_ROCM_ARCH="${GFX_TARGET}" \
              -DCOMPUTE_BACKEND=hip \
    && make -j"$(nproc)" \
    && pip wheel . --no-build-isolation --no-deps -w /artifacts/wheels

# --- Custom RCCL for gfx1151 -------------------------------------------------------------------
# Recipe lifted from the upstream build-rccl CI (vllm-toolboxes scripts/build_rccl_gfx1151.sh):
# clone kyuz0/rocm-systems @ gfx1151-rccl, configure projects/rccl for gfx1151-only, build.
# hipcc is resolved from PATH (rocm-sdk-devel puts it on /opt/venv/bin) rather than the upstream's
# hardcoded $ROCM_PATH/bin/hipcc, whose presence under the pip SDK root is unconfirmed (see notes).
# Collect the real SONAME file (cp -L dereferences the librccl.so.1 symlink) into lib64.
WORKDIR /opt
RUN git clone -b "${RCCL_REF}" "${RCCL_REPO}" rocm-systems \
    && cd rocm-systems/projects/rccl \
    && mkdir -p build_gfx1151 && cd build_gfx1151 \
    && HIPCC="$(command -v hipcc)" \
    && CXX="${HIPCC}" cmake .. \
        -DCMAKE_CXX_COMPILER="${HIPCC}" \
        -DDEFAULT_GPUS="${GFX_TARGET}" \
        -DGPU_TARGETS="${GFX_TARGET}" \
        -DAMDGPU_TARGETS="${GFX_TARGET}" \
        -DCMAKE_INSTALL_PREFIX=./install \
        -DBUILD_TESTS=OFF \
        -DGENERATE_SYM_KERNELS=OFF \
        -DENABLE_AMDSMI=OFF \
        -DCMAKE_BUILD_TYPE=Release \
    && make -j"$(nproc)" \
    && cp -Lv librccl.so.1 /artifacts/lib64/librccl.so.1

# --- Scratch carrier: ONLY the compiled outputs. -----------------------------------------------
FROM scratch
COPY --from=builder /artifacts /artifacts
