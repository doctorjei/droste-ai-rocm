# rocm-pin.env — single source of truth for the unified ROCm/TheRock pin.
# Every base + toolbox Containerfile reads these via ARG. ONE pinned TheRock
# gfx1151 build feeds ALL images (llama/ds4/comfyui/vllm/finetuning).
#
# Why this date: torch is the binding constraint. There are ZERO Linux torch
# wheels on the 7.14 line (June builds are win_amd64 only). The newest
# Linux + cp313 (Debian 13 = Python 3.13) torch wheel is on 7.13.0a20260501.
# rocm-sdk-devel + rocm-sdk-libraries-gfx1151 both exist at that exact date,
# so the whole set is ABI-matched from one index. This REPLACES both the apt
# ROCm 7.2.4 repo (llama/ds4) and the S3 therock-dist tarball (finetuning).
#
# Bump procedure: pick a newer date where torch (Linux, cp313) AND both
# rocm-sdk-* wheels coexist on ONE rocm version line; update all fields together.
# Verify provenance post-install: cat $(rocm-sdk path)/share/therock/therock_manifest.json

# Target arch. gfx1151-ONLY: native kernels exist (rocm-sdk-libraries-gfx1151, ~573MB).
# gfx1100 fast-path DECLINED — gfx110X-dgpu libs stuck at 7.10.0a (Nov 2025), version-
# mismatched vs our 7.13.0a; +280MB for an ABI-risky, temporary perf gain.
GFX_TARGET=gfx1151
ROCM_INDEX_URL=https://rocm.nightlies.amd.com/v2/$GFX_TARGET/
ROCM_PIN=7.13.0a20260501

# torch stack — all three share date 20260501, cp313, linux; standard pairing (torch 2.9 →
# torchvision 0.24 → torchaudio 2.9). Verified present on the v2/gfx1151 index 2026-07-05.
TORCH_VERSION=2.9.1+rocm$ROCM_PIN
TORCHVISION_VERSION=0.24.0+rocm$ROCM_PIN
TORCHAUDIO_VERSION=2.9.0+rocm$ROCM_PIN

# TheRock ROCm SDK, pip-installed (no S3 tarball, no apt repo)
#ROCM_SDK_DEVEL_VERSION=7.13.0a20260501            # build toolchain: hipcc, clang, headers
#ROCM_SDK_LIBRARIES_VERSION=7.13.0a20260501        # runtime kernels: rocBLAS/hipBLASLt/MIOpen (gfx1151-native)

ROCM_SDK_DEVEL_VERSION=$ROCM_PIN            # build toolchain: hipcc, clang, headers
ROCM_SDK_LIBRARIES_VERSION=$ROCM_PIN        # runtime kernels: rocBLAS/hipBLASLt/MIOpen (gfx1151-native)

# Measured wheel sizes (compressed download, 20260501):
#   torch cp313 ............... 577 MB   (runtime, torch images)
#   rocm-sdk-libraries-gfx1151  573 MB   (runtime, all images)
#   rocm-sdk-devel ........... 1644 MB   (BUILD base only, not shipped)
