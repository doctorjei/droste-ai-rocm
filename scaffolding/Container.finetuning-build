# droste-finetuning-build: builds LLM-Finetuning tools (various repositories) against pinned SDK

# Overrideable Arguments - General Build (override with '--build-arg <ARG_NAME>=<VALUE>'
ARG SERIES_NAME=droste
ARG ARCH_NAME=halo
ARG TARGET_NAME=finetuning-build
ARG BUILDER_DESC="builder image for bitsandbytes & custom RCCL"


ARG DESCRIPTION="compiled outputs for finetuning image"

# Image Names
ARG BASE_IMAGE=localhost/${SERIES_NAME}-build-base-${ARCH_NAME}

# Build image
FROM ${BASE_IMAGE} AS builder
ARG SERIES_NAME TARGET_NAME ARCH_NAME BUILDER_DESC
LABEL description="${SERIES_NAME}-${TARGET_NAME}-${ARCH_NAME}: ${BUILDER_DESC}"

# ROCm Pin
ARG GFX_TARGET=gfx1151
ARG ROCM_INDEX_URL=https://rocm.nightlies.amd.com/v2/${GFX_TARGET}/
ARG TORCH_VERSION=2.9.1+rocm7.13.0a20260501

# Pinned dependencies
ARG BITSANDBYTES_REPO=https://github.com/bitsandbytes-foundation/bitsandbytes.git
ARG BITSANDBYTES_REF=8ab26f751931610043f34938720d423bc80f5896
ARG RCCL_REPO=https://github.com/kyuz0/rocm-systems.git
ARG RCCL_REF=a2686c9f41e44a75459e4771b7f380358432b294

# Install torch & upgraded dependencies
RUN pip install --index-url ${ROCM_INDEX_URL} "torch==${TORCH_VERSION}" && \
      pip install --upgrade scikit-build-core setuptools wheel

RUN apt-get -qq update && apt-get -qq install -y --no-install-recommends \
      libdrm-dev && rm -rf /var/lib/apt/lists/* && apt-get clean

# bitsandbytes
RUN mkdir -p /artifacts/wheels /artifacts/lib64
WORKDIR /opt
RUN git clone "${BITSANDBYTES_REPO}" bitsandbytes \
    && cd bitsandbytes \
    && git checkout "${BITSANDBYTES_REF}" \
    && cmake -S . -DGPU_TARGETS="${GFX_TARGET}" \
              -DBNB_ROCM_ARCH="${GFX_TARGET}" \
              -DCOMPUTE_BACKEND=hip \
    && make -j"$(nproc)" \
    && pip wheel . --no-build-isolation --no-deps -w /artifacts/wheels

# Custom RCCL
WORKDIR /opt
RUN mkdir -p rocm-systems && cd rocm-systems \
    && git init -q && git remote add origin "${RCCL_REPO}" \
    && git fetch --depth 1 origin "${RCCL_REF}" && git checkout -q FETCH_HEAD \
    && cd projects/rccl \
    && mkdir -p build_gfx1151 && cd build_gfx1151 \
    && HIPCC="$(command -v hipcc)" \
    && CXX="${HIPCC}" cmake .. \
        -DCMAKE_CXX_COMPILER="${HIPCC}" \
        -DDEFAULT_GPUS="${GFX_TARGET}" \
        -DGPU_TARGETS="${GFX_TARGET}" \
        -DAMDGPU_TARGETS="${GFX_TARGET}" \
        -DCMAKE_INSTALL_PREFIX=./install \
        -DBUILD_TESTS=OFF \
        -DGENERATE_SYM_KERNELS=OFF \
        -DENABLE_AMDSMI=OFF \
        -DCMAKE_BUILD_TYPE=Release \
    && make -j"$(nproc)" \
    && cp -Lv librccl.so.1 /artifacts/lib64/librccl.so.1

# Copy artifacts
FROM scratch
ARG SERIES_NAME TARGET_NAME ARCH_NAME DESCRIPTION
LABEL description="${SERIES_NAME}-${TARGET_NAME}-${ARCH_NAME}: ${DESCRIPTION}"
COPY --from=builder /artifacts /artifacts
