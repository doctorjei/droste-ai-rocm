# droste-comfyui-halo: interactive ComfyUI + AMD studios on the unified ROCm base
# Ported from https://github.com/kyuz0/amd-strix-halo-comfyui-toolboxes

# Overrideable Arguments - General Build (override with '--build-arg <ARG_NAME>=<VALUE>'
ARG SERIES_NAME=droste
ARG ARCH_NAME=halo
ARG TARGET_NAME=comfyui
ARG DESCRIPTION="ComfyUI (interactive, Triton JIT)"
ARG BASE_IMAGE=localhost/${SERIES_NAME}-runtime-base-${ARCH_NAME}

# Overrideable Arguemnts - ROCM / TORCH
ARG ROCM_INDEX_URL=https://rocm.nightlies.amd.com/v2/gfx1151/
ARG TORCH_VERSION=2.9.1+rocm7.13.0a20260501
ARG TORCHVISION_VERSION=
ARG TORCHAUDIO_VERSION=
ARG TRANSFORMERS_VERSION=4.56.2

## ComfyUI, Custom Nodes, & AMD Studios (Pinned 2026-07-05)
#### COMFYUI_REF: comfyanonymous/ComfyUI        ESSENTIALS_REF: cubiq/ComfyUI_essentials
#### GGUF_REF: city96/ComfyUI-GGUF              AMDGPUMONITOR_REF: kyuz0/ComfyUI-AMDGPUMonitor
#### QWEN_STUDIO_REF: kyuz0/qwen-image-studio   WAN_STUDIO_REF: kyuz0/wan-video-studio
ARG COMFYUI_REF=985fb9d6adc974df9783d3d355cf86b992956212
ARG ESSENTIALS_REF=9d9f4bedfc9f0321c19faf71855e228c93bd0dc9
ARG AMDGPUMONITOR_REF=0c584ed28ed3678d96f631a6eff91be397c0baa4
ARG GGUF_REF=6ea2651e7df66d7585f6ffee804b20e92fb38b8a
ARG QWEN_STUDIO_REF=5e6659aab39b88f27334cf6eaebbe9b6dbc2eefe
ARG WAN_STUDIO_REF=b496fa3aa73b0aa628f1acb3d0b8f6de17570798

# --- IMAGE BUILD BEGINS HERE ---
FROM ${BASE_IMAGE}
LABEL description="${SERIES_NAME}-${TARGET_NAME}-${ARCH_NAME}: ${DESCRIPTION}"

## Dependencies: General / Media & Triton JIT (required at runtime)
RUN apt-get -qq update && apt-get -qq install -y --no-install-recommends \
            ffmpeg dialog git curl rsync libdrm2 pkg-config vim python3-pip \
            gcc g++ make binutils python3-dev && \
    rm -rf /var/lib/apt/lists/* && apt-get clean

## PIP: Torch Stack, GGUF, & Transformers (pinned if set) 
RUN pip install --pre --index-url ${ROCM_INDEX_URL} \
       "torch==${TORCH_VERSION}" \
       "torchvision${TORCHVISION_VERSION:+==${TORCHVISION_VERSION}}" \
       "torchaudio${TORCHAUDIO_VERSION:+==${TORCHAUDIO_VERSION}}" && \
    pip install gguf "transformers==${TRANSFORMERS_VERSION}"

# ComfyUI (core)
RUN git clone --depth=1 https://github.com/comfyanonymous/ComfyUI.git /opt/ComfyUI \
    && if [ -n "${COMFYUI_REF}" ]; then \
         git -C /opt/ComfyUI fetch --depth=1 origin "${COMFYUI_REF}" \
         && git -C /opt/ComfyUI checkout "${COMFYUI_REF}"; \
       fi
WORKDIR /opt/ComfyUI
RUN pip install -r requirements.txt \
    && pip install --prefer-binary \
       pillow opencv-python-headless imageio imageio-ffmpeg scipy \
       "huggingface_hub[hf_transfer]" pyyaml websocket-client

# ComfyUI Custom Nodes
WORKDIR /opt/ComfyUI/custom_nodes
RUN git clone --depth=1 https://github.com/cubiq/ComfyUI_essentials /opt/ComfyUI/custom_nodes/ComfyUI_essentials \
    && if [ -n "${ESSENTIALS_REF}" ]; then \
         git -C /opt/ComfyUI/custom_nodes/ComfyUI_essentials fetch --depth=1 origin "${ESSENTIALS_REF}" \
         && git -C /opt/ComfyUI/custom_nodes/ComfyUI_essentials checkout "${ESSENTIALS_REF}"; \
       fi
RUN git clone --depth=1 https://github.com/kyuz0/ComfyUI-AMDGPUMonitor /opt/ComfyUI/custom_nodes/ComfyUI-AMDGPUMonitor \
    && if [ -n "${AMDGPUMONITOR_REF}" ]; then \
         git -C /opt/ComfyUI/custom_nodes/ComfyUI-AMDGPUMonitor fetch --depth=1 origin "${AMDGPUMONITOR_REF}" \
         && git -C /opt/ComfyUI/custom_nodes/ComfyUI-AMDGPUMonitor checkout "${AMDGPUMONITOR_REF}"; \
       fi
RUN git clone --depth=1 https://github.com/city96/ComfyUI-GGUF /opt/ComfyUI/custom_nodes/ComfyUI-GGUF \
    && if [ -n "${GGUF_REF}" ]; then \
         git -C /opt/ComfyUI/custom_nodes/ComfyUI-GGUF fetch --depth=1 origin "${GGUF_REF}" \
         && git -C /opt/ComfyUI/custom_nodes/ComfyUI-GGUF checkout "${GGUF_REF}"; \
       fi

# Qwen Image Studio
WORKDIR /opt
RUN git clone --depth=1 https://github.com/kyuz0/qwen-image-studio /opt/qwen-image-studio \
    && if [ -n "${QWEN_STUDIO_REF}" ]; then \
         git -C /opt/qwen-image-studio fetch --depth=1 origin "${QWEN_STUDIO_REF}" \
         && git -C /opt/qwen-image-studio checkout "${QWEN_STUDIO_REF}"; \
       fi \
    && pip install -r /opt/qwen-image-studio/requirements.txt

# Wan Video Studio (explicit dep; not its requirements.txt).
RUN git clone --depth=1 https://github.com/kyuz0/wan-video-studio /opt/wan-video-studio \
    && if [ -n "${WAN_STUDIO_REF}" ]; then \
         git -C /opt/wan-video-studio fetch --depth=1 origin "${WAN_STUDIO_REF}" \
         && git -C /opt/wan-video-studio checkout "${WAN_STUDIO_REF}"; \
       fi \
    && pip install --prefer-binary \
       opencv-python-headless diffusers tokenizers accelerate \
       "imageio[ffmpeg]" easydict ftfy dashscope imageio-ffmpeg decord librosa

# --- Assets (copied into build context from upstream/comfyui) ---
# Helper scripts (ComfyUI-only) -> /opt.
COPY scripts/get_wan22.sh /opt/
COPY scripts/set_extra_paths.sh /opt/
COPY scripts/get_qwen_image.sh /opt/
COPY scripts/get_hunyuan15.sh /opt/
COPY scripts/get_ltx2.sh /opt/
COPY scripts/benchmark_workflows.py /opt/
COPY scripts/collect_perf_logs.py /opt/
COPY scripts/model_manager.py /opt/

# API workflow definitions + example inputs + UI workflows.
COPY workflows/API /opt/comfy-workflows
COPY workflows/input/ai-server.jpg /opt/ComfyUI/input/
COPY workflows/input/ai-server-2.png /opt/ComfyUI/input/
COPY workflows/input/example2.jpg /opt/ComfyUI/input/
COPY workflows/*.json /opt/ComfyUI/user/default/workflows/

# Permissions & trims (keep compilers/headers for Triton JIT at runtime).
RUN chmod -R a+rwX /opt && chmod +x /opt/*.sh || true \
    && find /opt/venv -type f -name "*.so" -exec strip -s {} + 2>/dev/null || true \
    && find /opt/venv -type d -name "__pycache__" -prune -exec rm -rf {} + \
    && pip cache purge || true \
    && rm -rf /root/.cache/pip || true

# Interactive login shell wiring (torch/AOTriton env, login banner, guards, core-dump suppression)
COPY scripts/01-rocm-envs.sh /etc/profile.d/01-rocm-envs.sh
COPY scripts/99-toolbox-banner.sh /etc/profile.d/99-toolbox-banner.sh
COPY scripts/zz-venv-last.sh /etc/profile.d/zz-venv-last.sh
RUN chmod 0644 /etc/profile.d/01-rocm-envs.sh /etc/profile.d/99-toolbox-banner.sh /etc/profile.d/zz-venv-last.sh \
    && printf 'ulimit -S -c 0\n' > /etc/profile.d/90-nocoredump.sh \
    && chmod 0644 /etc/profile.d/90-nocoredump.sh

WORKDIR /opt
CMD ["/bin/bash"]
