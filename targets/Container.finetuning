# droste-finetuning-halo: interactive, Jupyter LLM-finetuning toolbox (torch + HF/unsloth on halo)
# Ported from github.com/kyuz0/amd-strix-halo-llm-finetuning

# Overrideable Arguments - General Build (override with '--build-arg <ARG_NAME>=<VALUE>'
ARG SERIES_NAME=droste
ARG ARCH_NAME=halo
ARG TARGET_NAME=finetuning
ARG DESCRIPTION="LLM-Finetuning (${ARCH_NAME}): interactive, torch + HF/unsloth, custom RCCL"

# Image Names
ARG BASE_IMAGE=localhost/${SERIES_NAME}-torch-base-${ARCH_NAME}
ARG ARTIFACTS_IMAGE=localhost/${SERIES_NAME}-${TARGET_NAME}-build-${ARCH_NAME}

# Pinned (Torch version)
ARG GFX_TARGET=gfx1151
ARG TORCH_VERSION=2.9.1+rocm7.13.0a20260501
ARG ROCM_INDEX_URL=https://rocm.nightlies.amd.com/v2/${GFX_TARGET}/

# Pinned Dependencies
ARG FLASH_ATTENTION_REPO=https://github.com/ROCm/flash-attention.git
ARG FLASH_ATTENTION_REF=3f94643fb41bcedded28c85185a8e11d42ef1592
ARG UNSLOTH_REPO=https://github.com/unslothai/unsloth.git
ARG UNSLOTH_REF=07a7ff47b1b2b37c088b8e0d7ed7bf8710d9aa22

FROM ${ARTIFACTS_IMAGE} AS artifacts
FROM ${BASE_IMAGE}
ARG SERIES_NAME TARGET_NAME ARCH_NAME DESCRIPTION
ARG ROCM_INDEX_URL TORCH_VERSION FLASH_ATTENTION_REPO FLASH_ATTENTION_REF UNSLOTH_REPO UNSLOTH_REF
LABEL description="${SERIES_NAME}-${TARGET_NAME}-${ARCH_NAME}: ${DESCRIPTION}"

# Dependency installation (tools, libgomp1, torch)
RUN apt-get -qq update && apt-get -qq install -y --no-install-recommends \
      git curl patch libgomp1 && rm -rf /var/lib/apt/lists/* && apt-get clean

# Copy artifacts
COPY --from=artifacts /artifacts /artifacts

# bitsandbytes gfx1151 wheel and upstream version-parse fix with symlinks to real .so files.
RUN pip install --no-deps /artifacts/wheels/bitsandbytes-*.whl \
    && BNB_SO="$(ls /opt/venv/lib*/python*/site-packages/bitsandbytes/libbitsandbytes_rocm*.so | head -n1)" \
    && BNB_DIR="$(dirname "$BNB_SO")" \
    && ln -sf "$BNB_SO" "$BNB_DIR/libbitsandbytes_rocm7.12.so" \
    && ln -sf "$BNB_SO" "$BNB_DIR/libbitsandbytes_rocm82.so"

# Custom RCCL: overwrite the SDK's stock librccl
RUN if [ -e "${ROCM_PATH}/lib/librccl.so.1.0" ]; then \
        cp -fv /artifacts/lib64/librccl.so.1 "${ROCM_PATH}/lib/librccl.so.1.0"; \
    fi \
    && find /opt/venv -name "librccl.so.1" -exec cp -fv /artifacts/lib64/librccl.so.1 {} + \
    && ldconfig

# HF finetuning stack (upstream pins)
RUN pip install --no-cache-dir \
      jq transformers peft accelerate safetensors sentencepiece huggingface-hub datasets trl \
      einops unsloth_zoo==2026.1.4 tqdm==4.67.1 ipywidgets==8.1.7 ipykernel==6.30.1 \
      traitlets==5.14.3 jupyter_core==5.8.1 jupyterlab

# Flash-Attention (ROCm Triton backend); skips CUDA C++ extension & installs pure Python/Triton
ENV FLASH_ATTENTION_TRITON_AMD_ENABLE=TRUE
RUN git clone "${FLASH_ATTENTION_REPO}" /tmp/flash-attention \
    && cd /tmp/flash-attention \
    && git checkout "${FLASH_ATTENTION_REF}" \
    && pip install --no-cache-dir packaging \
    && python setup.py install \
    && rm -rf /tmp/flash-attention

# Unsloth (pinned commit + PR 4109 RDNA fixes)
RUN git clone "${UNSLOTH_REPO}" /tmp/unsloth \
    && cd /tmp/unsloth \
    && git checkout "${UNSLOTH_REF}" \
    && curl -sL https://github.com/unslothai/unsloth/pull/4109.diff | patch -p1 \
    && pip install --no-cache-dir . \
    && rm -rf /tmp/unsloth

# Droste runtime assets under the /opt/resources umbrella:
#   scripts/   — helper CLIs + lib.py, read-only, on PATH (CLIs) + PYTHONPATH (from lib import ...)
#   templates/ — templates.yaml + pristine starter notebooks (seed if_empty -> /opt/workspace)
#   build-spec — this port's mounts + service, consumed by the shared entrypoint
COPY scripts    /opt/resources/scripts
COPY templates  /opt/resources/templates
COPY build-spec /opt/resources/build-spec
ENV PATH=/opt/resources/scripts:$PATH PYTHONPATH=/opt/resources/scripts

# /opt/workspace = the USER'S workspace bind mountpoint — ships EMPTY (CRITICAL at
# runtime; the starter notebooks seed in from templates/workspace only when empty).
RUN mkdir -p /opt/workspace

# Runtime env scripts (profile.d)
COPY profile.d/01-rocm-env-for-triton.sh /etc/profile.d/01-rocm-env-for-triton.sh
COPY profile.d/99-toolbox-banner.sh      /etc/profile.d/99-toolbox-banner.sh
COPY profile.d/zz-venv-last.sh           /etc/profile.d/zz-venv-last.sh
RUN chmod 0644 /etc/profile.d/*.sh \
    && printf 'ulimit -S -c 0\n' > /etc/profile.d/90-nocoredump.sh \
    && chmod 0644 /etc/profile.d/90-nocoredump.sh

# Jupyter kernel points at the venv python; friendly display name (upstream parity).
RUN /opt/venv/bin/python -m ipykernel install --name=python3 --display-name "Python (venv)" --prefix=/opt/venv

# Group-writable venv so the distrobox-lane box user (in group `droste`) can
# pip-install into the baked venv after overlay copy-up (dirs setgid → copy-up
# is metadata-only; new files inherit the group). Re-applied here AFTER this
# port's pip installs + kernel install (runtime-base did it for its own venv content).
RUN chgrp -R droste /opt/venv \
    && chmod -R g+rwX /opt/venv \
    && find /opt/venv -type d -exec chmod g+s {} +

# Shared droste entrypoint (server lane): resolves mounts/criticals/templates from
# /opt/resources/build-spec, then execs JupyterLab on :8888. distrobox/toolbx
# override the entrypoint and get the interactive lane. Writability comes from the
# venv overlay + the user's workspace bind — no world-writable /opt.
ENTRYPOINT ["/opt/resources/resolve/droste-entrypoint.sh"]
