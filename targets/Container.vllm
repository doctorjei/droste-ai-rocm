# droste-vllm-halo: vLLM toolbox (TheRock torch + prebuilt wheels) on halo.
# Ported from github.com/kyuz0/amd-strix-halo-toolboxes

# Overrideable Arguments - General Build (override with '--build-arg <ARG_NAME>=<VALUE>'
ARG SERIES_NAME=droste
ARG ARCH_NAME=halo
ARG TARGET_NAME=vllm
ARG DESCRIPTION="vLLM toolbox (TheRock torch & prebuilt wheels)"

# Image Names
ARG BASE_IMAGE=localhost/${SERIES_NAME}-torch-base-${ARCH_NAME}
ARG ARTIFACTS_IMAGE=localhost/${SERIES_NAME}-${TARGET_NAME}-build-${ARCH_NAME}

# Build image
FROM ${ARTIFACTS_IMAGE} AS artifacts
FROM ${BASE_IMAGE}
ARG SERIES_NAME TARGET_NAME ARCH_NAME DESCRIPTION
LABEL description="${SERIES_NAME}-${TARGET_NAME}-${ARCH_NAME}: ${DESCRIPTION}"

# ROCM / Torch Pin
ARG GFX_TARGET=gfx1151
ARG ROCM_INDEX_URL=https://rocm.nightlies.amd.com/v2/${GFX_TARGET}/
ARG TORCH_VERSION=2.9.1+rocm7.13.0a20260501

# Runtime libraries
RUN apt-get -qq update && apt-get -qq install -y --no-install-recommends \
      libnuma1 numactl libgomp1 && rm -rf /var/lib/apt/lists/* && apt-get clean

# Copy artifacts. patch_aiter_headers.py is parked under /opt/resources/scripts/ (it is
# used at BUILD to re-patch the installed aiter; it need not sit at /opt root forever).
COPY --from=artifacts /artifacts/wheels /tmp/wheels
COPY --from=artifacts /artifacts/fp8    /opt/fp8
COPY scripts/patch_aiter_headers.py /opt/resources/scripts/patch_aiter_headers.py

# Install order matters:
#  1. aiter + flash-attn wheels (--no-deps: their deps are torch/triton, already present).
#  2. re-apply patch_aiter_headers.py to the freshly-installed aiter — its ck_tile headers are
#     used by aiter's RUNTIME JIT on gfx1151 (the artifacts stage patched its own copy; the
#     shipped wheel is pre-patch, so patch it again here).
#  3. vLLM wheel WITH deps so pip resolves transformers/etc. from PyPI (torch already satisfied).
#     Use the legacy resolver for this RUN: vLLM pins `torch==2.9.1` while the installed wheel is
#     `2.9.1+rocm7.13.0a20260501`, and the new resolvelib backtracker explores an exploding search
#     space over that (+ the large dep graph) and dies with RecursionError in _has_route_to_root
#     (survives even a 100k recursion limit — it's pathological backtracking, not mere depth). The
#     legacy resolver takes the first satisfying candidate (our torch satisfies ==2.9.1) and skips
#     the backtracking entirely. Scoped to this RUN via the env export.
#  4. ray (upstream installs it explicitly; used by the cluster launcher paths).
#  5. trim /opt/fp8 to the RUNTIME import surface: keep top-level *.py + LICENSE/NOTICE +
#     licenses/ (the live Triton JIT kernels imported via PYTHONPATH=/opt/fp8); drop the
#     non-runtime baggage (bench/ docs/ serve_*.sh README.md .gitignore) from the checkout.
RUN export PIP_USE_DEPRECATED=legacy-resolver \
    && pip install --no-deps /tmp/wheels/amd_aiter*.whl /tmp/wheels/flash_attn*.whl \
    && python /opt/resources/scripts/patch_aiter_headers.py \
    && pip install /tmp/wheels/vllm*.whl \
    && pip install ray \
    && rm -rf /tmp/wheels /root/.cache/pip \
    && rm -rf /opt/fp8/bench /opt/fp8/docs /opt/fp8/README.md /opt/fp8/serve_*.sh /opt/fp8/.gitignore

# Runtime shell env + banner
COPY profile.d/01-rocm-env-for-triton.sh /etc/profile.d/01-rocm-env-for-triton.sh
COPY profile.d/99-toolbox-banner.sh      /etc/profile.d/99-toolbox-banner.sh
COPY profile.d/zz-venv-last.sh           /etc/profile.d/zz-venv-last.sh
RUN chmod 0644 /etc/profile.d/01-rocm-env-for-triton.sh \
      /etc/profile.d/99-toolbox-banner.sh /etc/profile.d/zz-venv-last.sh

# FP8 shim + runtime env. VLLM_NO_USAGE_STATS=1 opts out of vLLM usage/do-not-track
# reporting (baked, per the hidden-state disposition — we do NOT persist ~/.config/vllm).
ENV PYTHONPATH=/opt/fp8 \
    FLASH_ATTENTION_TRITON_AMD_ENABLE=TRUE \
    VLLM_TARGET_DEVICE=rocm \
    VLLM_USE_TRITON_AWQ=1 \
    TORCH_ROCM_AOTRITON_ENABLE_EXPERIMENTAL=1 \
    MIOPEN_FIND_MODE=FAST \
    VLLM_DISABLE_COMPILE_CACHE=1 \
    VLLM_NO_USAGE_STATS=1 \
    PYTHONNOUSERSITE=1

# Droste runtime contract: per-port build-spec + config template + shared entrypoint.
# gen_vllm_config.py runs at BUILD, harvesting the pinned upstream MODEL_TABLE (vendored,
# hermetic) into the config template that templates.yaml seeds to /opt/data on first run.
COPY build-spec                 /opt/resources/build-spec
COPY templates/                 /opt/resources/templates/
COPY scripts/gen_vllm_config.py /opt/resources/scripts/gen_vllm_config.py
COPY upstream/models.py         /opt/resources/scripts/vllm_models_pinned.py
RUN python3 /opt/resources/scripts/gen_vllm_config.py \
      --models /opt/resources/scripts/vllm_models_pinned.py \
      --out    /opt/resources/templates/vllm_config.yaml

ENTRYPOINT ["/opt/resources/resolve/droste-entrypoint.sh"]
