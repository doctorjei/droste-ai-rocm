# Nothing is bound at /opt/models yet.
#
# /opt/models is the OPTIONAL, read-only bind point for a local model collection.
# Bind a host directory of models to make them available, e.g.
#   podman run … -v /host/models:/opt/models:ro …
#   (distrobox.ini:  volume=/host/models:/opt/models:ro)
# then point vLLM at a model via /opt/data/vllm_config.yaml:
#   model: /opt/models/<model-dir-or-file>
#
# Models named by HF repo id in the config download into the shared HF cache
# (~/.cache/huggingface) instead — no /opt/models bind needed for those.
#
# This file was created to note you have been informed; deleting it re-shows
# the notice at the next start.
